---
interface Props {
  slug: string;
  title: string;
  excerpt?: string;
  readTime?: string;
  imageSrc?: string;
  imageAlt?: string;
  pullQuote?: string;
  variant?: 'default' | 'large';
}

const { slug, title, excerpt, readTime, imageSrc, imageAlt = '', pullQuote, variant = 'default' } = Astro.props;
---

<a
  href={`/stories/${slug}`}
  class:list={['story-card', variant === 'large' ? 'story-card--large' : '']}
>
  {imageSrc && (
    <div class="story-card__img-wrap">
      <img src={imageSrc} alt={imageAlt} class="story-card__img" loading="lazy" decoding="async" />
    </div>
  )}
  <div class="story-card__body">
    {readTime && <span class="text-eyebrow">{readTime} read</span>}
    <h3 class="story-card__title">{title}</h3>
    {pullQuote && (
      <p class="story-card__quote">"{pullQuote}"</p>
    )}
    {!pullQuote && excerpt && (
      <p class="story-card__excerpt">{excerpt}</p>
    )}
    <span class="story-card__cta" aria-hidden="true">
      Read story
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
        <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</a>

<style>
  .story-card {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1px solid var(--c-border);
    border-radius: 1.25rem;
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  :root.dark .story-card { background: var(--c-bg-alt); }
  .story-card:hover {
    box-shadow: 0 8px 40px rgba(47, 47, 47, 0.1);
    transform: translateY(-2px);
  }
  .story-card--large { flex-direction: column; }
  @media (min-width: 640px) {
    .story-card--large { flex-direction: row; }
  }

  .story-card__img-wrap {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--c-bg-deep);
    flex-shrink: 0;
  }
  .story-card--large .story-card__img-wrap {
    aspect-ratio: 4/3;
  }
  @media (min-width: 640px) {
    .story-card--large .story-card__img-wrap {
      width: 42%;
      aspect-ratio: auto;
    }
  }
  .story-card__img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .story-card:hover .story-card__img { transform: scale(1.04); }

  .story-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .story-card--large .story-card__body {
    padding: 2rem;
    justify-content: center;
  }

  .story-card__title {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--c-text);
    line-height: 1.3;
    margin: 0.375rem 0 0.75rem;
  }
  .story-card--large .story-card__title {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
  }

  .story-card__quote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--c-text-muted);
    margin: 0 0 1rem;
  }
  .story-card__excerpt {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--c-text-muted);
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .story-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--c-text-faint);
    margin-top: auto;
    transition: color 0.2s;
  }
  .story-card:hover .story-card__cta { color: var(--c-text); }
</style>
