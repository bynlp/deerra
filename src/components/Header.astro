<!-- ---
import { getMenu } from 'emdash';

const menu = await getMenu('primary');

const currentPath = Astro.url.pathname;

const navLinks = menu?.items ?? [
  { label: 'Moments',   url: '/moments' },
  { label: 'Stories',   url: '/stories' },
  { label: 'Living',    url: '/living' },
  { label: 'Companion', url: '/companion' },
];
---

<header id="site-header">
  <div class="header-inner">

    {/* ── Logo ── */}
    <a href="/" class="logo-link" aria-label="Mindful AI — Home">
      <span class="logo-dot" aria-hidden="true">
        <span class="logo-dot-inner"></span>
      </span>
      <span class="logo-text">Mindful AI</span>
    </a>

    {/* ── Desktop Nav (center) ── */}
    <nav class="desktop-nav" aria-label="Main navigation">
      <ul role="list">
        {navLinks.map((item) => {
          const isActive = currentPath.startsWith(item.url) && item.url !== '/';
          return (
            <li>
              <a href={item.url} class={isActive ? 'nav-link active' : 'nav-link'}>
                {item.label}
              </a>
            </li>
          );
        })}
        <li>
          <a href="/thoughts" class="nav-link muted">Thoughts</a>
        </li>
      </ul>
    </nav>

    {/* ── Right controls ── */}
    <div class="header-controls">

      {/* Dark / light toggle */}
      <button id="theme-toggle" class="theme-btn" aria-label="Toggle dark mode">
        <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      {/* Hamburger (mobile only) */}
      <button
        id="hamburger"
        class="hamburger-btn"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="bar bar-top"></span>
        <span class="bar bar-mid"></span>
        <span class="bar bar-bot"></span>
      </button>
    </div>
  </div>

  {/* ── Mobile drawer ── */}
  <div id="mobile-menu" class="mobile-drawer" aria-hidden="true">
    <ul role="list">
      {navLinks.map((item) => (
        <li>
          <a href={item.url} class="mobile-link">{item.label}</a>
        </li>
      ))}
      <li>
        <a href="/thoughts" class="mobile-link" style="opacity: 0.6;">Thoughts</a>
      </li>
    </ul>
  </div>
</header>

{/* Spacer = header height */}
<div style="height: var(--header-h);" aria-hidden="true"></div>

<style>
  /* ── Token ── */
  :root { --header-h: 64px; }
  @media (min-width: 768px) { :root { --header-h: 72px; } }

  /* ── Shell ── */
  #site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    border-bottom: 1px solid transparent;
    transition: background 0.35s ease, border-color 0.35s ease, backdrop-filter 0.35s ease;
  }
  #site-header.scrolled {
    background: rgba(247, 245, 242, 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: rgba(227, 222, 215, 0.7);
  }
  :root.dark #site-header.scrolled {
    background: rgba(26, 24, 21, 0.92);
    border-bottom-color: rgba(60, 56, 50, 0.7);
  }

  /* ── Inner row: logo | nav | controls ── */
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: var(--header-h);
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }

  /* ── Logo ── */
  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-dot {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--c-accent-light);
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.25s ease;
  }
  .logo-link:hover .logo-dot { transform: scale(1.1); }
  .logo-dot-inner {
    width: 11px; height: 11px;
    border-radius: 50%;
    background: var(--c-accent-dark);
  }
  .logo-text {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--c-text);
  }

  /* ── Desktop nav ── */
  .desktop-nav { display: none; }
  @media (min-width: 768px) {
    .desktop-nav {
      display: flex;
      flex: 1;
      justify-content: center;
    }
  }
  .desktop-nav ul {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    list-style: none;
    margin: 0; padding: 0;
  }
  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--c-text-muted);
    text-decoration: none;
    position: relative;
    padding-bottom: 2px;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .nav-link:hover { color: var(--c-text); }
  .nav-link.active { color: var(--c-text); }
  .nav-link.active::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -3px;
    height: 1px;
    background: var(--c-accent);
  }
  .nav-link.muted { color: var(--c-text-faint); }
  .nav-link.muted:hover { color: var(--c-text-muted); }

  /* ── Controls row ── */
  .header-controls {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  /* ── Theme button ── */
  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 1px solid var(--c-border);
    background: transparent;
    color: var(--c-text-muted);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .theme-btn:hover {
    background: var(--c-bg-deep);
    color: var(--c-text);
  }
  /* Light mode → show moon; dark mode → show sun */
  .icon-sun  { display: none; }
  .icon-moon { display: block; }
  :root.dark .icon-sun  { display: block; }
  :root.dark .icon-moon { display: none; }

  /* ── Hamburger ── */
  .hamburger-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 36px; height: 36px;
    padding: 6px;
    border: 1px solid var(--c-border);
    border-radius: 8px;
    background: transparent;
    cursor: pointer;
    transition: background 0.2s;
  }
  .hamburger-btn:hover { background: var(--c-bg-deep); }
  @media (min-width: 768px) { .hamburger-btn { display: none; } }

  .bar {
    display: block;
    height: 1.5px;
    border-radius: 2px;
    background: var(--c-text);
    transform-origin: center;
    transition: transform 0.28s ease, opacity 0.28s ease, width 0.28s ease;
  }
  .bar-top { width: 18px; }
  .bar-mid { width: 18px; }
  .bar-bot { width: 12px; margin-left: auto; }

  /* Open state */
  .hamburger-btn[aria-expanded="true"] .bar-top {
    transform: translateY(6.5px) rotate(45deg);
  }
  .hamburger-btn[aria-expanded="true"] .bar-mid {
    opacity: 0; transform: scaleX(0);
  }
  .hamburger-btn[aria-expanded="true"] .bar-bot {
    width: 18px;
    margin-left: 0;
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── Mobile drawer ── */
  .mobile-drawer {
    display: none;
    background: var(--c-bg);
    border-top: 1px solid var(--c-border);
    padding-bottom: 1rem;
  }
  .mobile-drawer.open { display: block; }
  @media (min-width: 768px) { .mobile-drawer { display: none !important; } }

  .mobile-drawer ul {
    list-style: none;
    margin: 0;
    padding: 0 clamp(1.25rem, 5vw, 3rem);
  }
  .mobile-link {
    display: block;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--c-border);
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--c-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .mobile-link:hover { color: var(--c-text); }
  .mobile-drawer li:last-child .mobile-link { border-bottom: none; }
</style>

