---
interface Props {
  question: string;
  answer: string;
  id: string;
}

const { question, answer, id } = Astro.props;
const panelId = `faq-panel-${id}`;
const triggerId = `faq-trigger-${id}`;
---

<div class="faq-item card card-cream">
  <button
    id={triggerId}
    class="faq-trigger w-full text-left flex items-start justify-between gap-4"
    aria-expanded="false"
    aria-controls={panelId}
  >
    <span class="faq-question">
      {question}
    </span>

    <span class="faq-icon" aria-hidden="true">
      <svg class="faq-plus" width="12" height="12" viewBox="0 0 12 12">
        <path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <svg class="faq-minus hidden" width="12" height="12" viewBox="0 0 12 12">
        <path d="M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </span>
  </button>

  <div
    id={panelId}
    role="region"
    aria-labelledby={triggerId}
    class="faq-panel hidden"
  >
    <p class="faq-answer">
      {answer}
    </p>
  </div>
</div>

<style>
  .faq-item {
    padding: 1.5rem 1.6rem;
  }

  .faq-trigger {
    cursor: pointer;
  }

  .faq-question {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--c-text);
    line-height: 1.5;
    letter-spacing: -0.01em;
  }

  .faq-icon {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--c-bg);
    color: var(--c-text-muted);
    transition: var(--transition);
  }

  .faq-panel {
    margin-top: 1rem;
  }

  .faq-answer {
    color: var(--c-text-muted);
    font-size: 0.98rem;
    line-height: 1.75;
  }

  /* 打开状态 */
  .faq-trigger[aria-expanded="true"] .faq-icon {
    background: var(--c-accent-light);
    color: var(--c-accent-deep);
  }
</style>

<script>
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      const panel = document.getElementById(trigger.getAttribute('aria-controls'));

      const plus = trigger.querySelector('.faq-plus');
      const minus = trigger.querySelector('.faq-minus');

      if (expanded) {
        trigger.setAttribute('aria-expanded', 'false');
        panel.classList.add('hidden');
        plus.classList.remove('hidden');
        minus.classList.add('hidden');
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        panel.classList.remove('hidden');
        plus.classList.add('hidden');
        minus.classList.remove('hidden');
      }
    });
  });
</script>
