---
import { getMenu } from 'emdash';

const exploreMenu = await getMenu('footer_explore');
const infoMenu    = await getMenu('footer_info');

const exploreLinks = exploreMenu?.items ?? [
  { label: 'Moments', url: '/moments' },
  { label: 'Stories', url: '/stories' },
  { label: 'Living',  url: '/living'  },
];

const infoLinks = infoMenu?.items ?? [
  { label: 'Companion', url: '/companion' },
  { label: 'Thoughts',  url: '/thoughts'  },
  { label: 'Future',    url: '/future'    },
  { label: 'Privacy',   url: '/privacy'   },
  { label: 'Contact',   url: '/contact'   },
];
---

<footer id="site-footer">
  <div class="footer-inner">

    {/* ── Left: logo + tagline ── */}
    <div class="footer-col footer-col--brand">
      <a href="/" class="footer-logo" aria-label="Mindful AI — Home">
        <span class="footer-logo-dot" aria-hidden="true">
          <span class="footer-logo-dot-inner"></span>
        </span>
        <span class="footer-logo-text">Mindful AI</span>
      </a>

      <p class="footer-tagline">
        A quiet space to think, feel, and reset — whenever you need it.
      </p>

      <div class="footer-accent-line" aria-hidden="true"></div>
    </div>

    {/* ── Middle: Explore ── */}
    <div class="footer-col">
      <p class="footer-heading">Explore</p>
      <ul class="footer-links" role="list">
        {exploreLinks.map((item) => (
          <li>
            <a href={item.url} class="footer-link">{item.label}</a>
          </li>
        ))}
      </ul>
    </div>

    {/* ── Right: Info ── */}
    <div class="footer-col">
      <p class="footer-heading">Info</p>
      <ul class="footer-links" role="list">
        {infoLinks.map((item) => (
          <li>
            <a href={item.url} class="footer-link">{item.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  {/* ── Bottom bar ── */}
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copy">
        © {new Date().getFullYear()} Mindful AI. All rights reserved.
      </p>
      <p class="footer-disclaimer">
        Not a clinical tool. Not a replacement for professional care.
      </p>
    </div>
  </div>
</footer>

<style>
  /* ── Footer shell ── */
  #site-footer {
    background: var(--c-bg-alt);
    border-top: 1px solid var(--c-border);
    margin-top: auto;
  }

  /* ── Main grid: always 3 columns on md+ ── */
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;        /* mobile: single column */
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem clamp(1.25rem, 5vw, 3rem) 3rem;
  }
  @media (min-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;  /* tablet: 2 col */
    }
    .footer-col--brand { grid-column: 1 / -1; } /* brand full-width on tablet */
  }
  @media (min-width: 900px) {
    .footer-inner {
      grid-template-columns: 1.6fr 1fr 1fr; /* desktop: 3 col */
      gap: 3rem;
    }
    .footer-col--brand { grid-column: auto; } /* reset */
  }

  /* ── Brand column ── */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .footer-logo-dot {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--c-accent-light);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .footer-logo-dot-inner {
    width: 11px; height: 11px;
    border-radius: 50%;
    background: var(--c-accent-dark);
  }
  .footer-logo-text {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--c-text);
  }
  .footer-tagline {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--c-text-muted);
    max-width: 22rem;
    margin: 0;
  }
  .footer-accent-line {
    width: 2rem;
    height: 1px;
    background: var(--c-accent);
    margin-top: 1.5rem;
  }

  /* ── Link columns ── */
  .footer-heading {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-text-faint);
    margin: 0 0 1.1rem 0;
  }
  .footer-links {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--c-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover { color: var(--c-text); }

  /* ── Bottom bar ── */
  .footer-bottom {
    border-top: 1px solid var(--c-border);
  }
  .footer-bottom-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem clamp(1.25rem, 5vw, 3rem);
  }
  @media (min-width: 640px) {
    .footer-bottom-inner {
      flex-direction: row;
      gap: 1rem;
    }
  }
  .footer-copy {
    font-size: 0.75rem;
    color: var(--c-text-faint);
    margin: 0;
  }
  .footer-disclaimer {
    font-size: 0.75rem;
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--c-text-faint);
    margin: 0;
  }
</style>
