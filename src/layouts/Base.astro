---
/**
 * Base.astro — Site-wide layout
 *
 * Handles ALL SEO and GEO (Generative Engine Optimization) meta.
 * Pages pass their CMS fields directly; this layout composes the <head>.
 *
 * Key meta for LLM/AI search engines (Perplexity, ChatGPT, Gemini):
 *  - <meta name="description"> — primary snippet
 *  - <meta name="abstract">    — LLM summary (non-standard but parsed by crawlers)
 *  - <meta name="subject">     — LLM intent / audience
 *  - <link rel="canonical">    — deduplication
 *  - Open Graph                — social + AI card preview
 *  - JSON-LD via <slot name="schema"> — structured data
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from 'emdash/ui';
import { createPublicPageContext } from 'emdash/page';

interface Props {
  /* ── Core ── */
  title?: string;
  description?: string;           // meta description (150-160 chars)
  ogImage?: string;

  /* ── Advanced SEO ── */
  canonicalUrl?: string;          // override; defaults to current URL
  noIndex?: boolean;              // true = noindex,nofollow
  publishedAt?: string;           // ISO 8601 for article:published_time
  modifiedAt?: string;            // ISO 8601 for article:modified_time
  authorName?: string;

  /* ── GEO / LLM meta ── */
  llmSummary?: string;            // 2-4 sentence factual summary for AI crawlers
  llmIntent?: string;             // "This content is for [audience] who want [goal]"
  focusKeyword?: string;          // primary keyword signal

  /* ── EmDash content context ── */
  content?: { collection: string; id: string; slug?: string | null };
}

const {
  title = 'Mindful AI',
  description = 'A quiet space to think, feel, and reset. Explore how people use AI for everyday emotional moments.',
  ogImage,
  canonicalUrl,
  noIndex = false,
  publishedAt,
  modifiedAt,
  authorName,
  llmSummary,
  llmIntent,
  focusKeyword,
  content,
} = Astro.props;

const siteUrl  = Astro.url.origin;
const pageUrl  = Astro.url.href;
const canonical = canonicalUrl ?? pageUrl;

// Page title: if it's already the brand name keep it; else suffix it
const siteTitle = title === 'Mindful AI' ? title : `${title} — Mindful AI`;

const pageCtx = createPublicPageContext({
  Astro,
  kind: content ? 'content' : 'custom',
  pageType: 'website',
  title: siteTitle,
  description,
  image: ogImage,
  content,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    {/* ── Flash prevention: apply stored dark/light theme before paint ── */}
    <script is:inline>
      (function(){try{var t=localStorage.getItem("theme"),d=window.matchMedia("(prefers-color-scheme: dark)").matches;if(t==="dark"||(!t&&d))document.documentElement.classList.add("dark");else document.documentElement.classList.remove("dark")}catch(e){}})();
    </script>

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* ── Primary SEO ── */}
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    {focusKeyword && <meta name="keywords" content={focusKeyword} />}
    <link rel="canonical" href={canonical} />
    {noIndex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }

    {/* ── GEO / LLM-optimized meta ─────────────────────────────────────────
        These non-standard meta tags are parsed by AI search crawlers
        (Perplexity, ChatGPT browsing, Gemini) as primary content signals.
        llmSummary → "abstract"  : factual 2-4 sentence summary
        llmIntent  → "subject"   : audience + goal description
        ─────────────────────────────────────────────────────────────────── */}
    {llmSummary && <meta name="abstract" content={llmSummary} />}
    {llmIntent  && <meta name="subject"  content={llmIntent} />}
    {llmSummary && <meta name="summary"  content={llmSummary} />}
    {authorName && <meta name="author"   content={authorName} />}

    {/* ── Open Graph ── */}
    <meta property="og:site_name"   content="Mindful AI" />
    <meta property="og:title"       content={siteTitle} />
    <meta property="og:description" content={llmSummary ?? description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:type"        content={publishedAt ? 'article' : 'website'} />
    {ogImage && <meta property="og:image"       content={ogImage} />}
    {ogImage && <meta property="og:image:width"  content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    {publishedAt && <meta property="article:published_time" content={publishedAt} />}
    {modifiedAt  && <meta property="article:modified_time"  content={modifiedAt} />}

    {/* ── Twitter / X Card ── */}
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={siteTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {/* ── EmDash head contributions (visual editing, CMS signals) ── */}
    <EmDashHead page={pageCtx} />

    {/* ── JSON-LD slot: pages inject their own <SchemaOrg> components ── */}
    <slot name="schema" />
  </head>

  <body>
    <EmDashBodyStart page={pageCtx} />
    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
    <EmDashBodyEnd page={pageCtx} />

    {/* ── Scroll reveal (IntersectionObserver) ── */}
    <script>
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
        }),
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal, .stagger-children').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
