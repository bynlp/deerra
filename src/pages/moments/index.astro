---
import Base from '../../layouts/Base.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { getEmDashCollection } from 'emdash';

const { entries: moments, cacheHint } = await getEmDashCollection('moments', {
  status: 'published', limit: 24,
});
Astro.cache.set(cacheHint);

const pageUrl = Astro.url.href;
const siteUrl = Astro.url.origin;
---

<Base
  title="Moments — Find the Feeling Closest to Yours"
  description="Emotional entry points for AI companionship — late-night anxiety, work overwhelm, overthinking, loneliness. Find your moment and discover stories, prompts, and practices."
  llmSummary="A categorized collection of emotional moments where AI companionship provides value — including late-night anxiety, workplace overwhelm, rumination, and loneliness. Each moment includes context, AI conversation prompts, and links to related stories."
  llmIntent="Adults experiencing a specific emotional state looking for relevant content, AI conversation prompts, or relatable stories."
  focusKeyword="AI companion emotional moments"
>
  <SchemaOrg
    slot="schema"
    type="WebPage"
    url={pageUrl}
    siteUrl={siteUrl}
    title="Moments"
    description="Emotional entry points for AI companionship."
    breadcrumbs={[{ label: 'Moments', url: '/moments' }]}
  />

  <section class="moments-header">
    <div class="moments-header__bg" aria-hidden="true"></div>
    <div class="container-site moments-header__content">
      <p class="text-eyebrow">Where are you right now?</p>
      <h1>Real-Life Moments</h1>
      <div class="divider"></div>
      <p class="moments-header__desc">
        Find the feeling that's closest to yours. No diagnosis, no labels — just moments that feel true.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-site">
      {moments.length > 0 ? (
        <div class="moments-grid stagger-children">
          {moments.map((m) => (
            <a href={`/moments/${m.id}`} class="moment-card">
              <div class="moment-card__inner">
                {m.data.icon && (
                  <div class="moment-card__icon" aria-hidden="true">{m.data.icon}</div>
                )}
                <h2 class="moment-card__title">{m.data.title}</h2>
                {m.data.subtitle && (
                  <p class="moment-card__tagline">{m.data.subtitle}</p>
                )}
                {m.data.opening_hook && (
                  <p class="moment-card__hook">{m.data.opening_hook}</p>
                )}
                <div class="moment-card__tags">
                  {m.data.emotion_category && (
                    <span class="tag">{m.data.emotion_category}</span>
                  )}
                  {m.data.time_of_day && (
                    <span class="tag">{m.data.time_of_day}</span>
                  )}
                </div>
                <span class="moment-card__cta" aria-hidden="true">
                  Explore →
                </span>
              </div>
              <div class="moment-card__wash" aria-hidden="true"></div>
            </a>
          ))}
        </div>
      ) : (
        <div class="moments-empty">
          <p>Moments are being added. Check back soon.</p>
          <a href="/" class="btn btn-ghost">← Back home</a>
        </div>
      )}
    </div>
  </section>

  <section class="section" style="background: var(--c-bg-alt);">
    <div class="container-narrow" style="text-align: center;">
      <p class="reveal" style="font-family: var(--font-serif); font-style: italic; font-size: 1.2rem; color: var(--c-text-muted);">
        "Sometimes just naming it is the beginning."
      </p>
      <a href="/stories" class="btn btn-ghost reveal" style="margin-top: 1.5rem; display: inline-flex;">
        Read others' experiences
      </a>
    </div>
  </section>
</Base>

<style>
  .moments-header {
    position: relative; overflow: hidden;
    padding: 5rem clamp(1.25rem,5vw,3rem) 4rem;
    background: var(--c-bg-alt);
  }
  .moments-header__bg {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 50% 80% at 80% 50%, rgba(230,199,163,0.18) 0%, transparent 60%);
  }
  .moments-header__content { position: relative; z-index: 1; }
  .moments-header__desc {
    font-size: 1.1rem; line-height: 1.7;
    color: var(--c-text-muted); max-width: 36rem; margin-top: 0.75rem;
  }

  .moments-grid {
    display: grid; grid-template-columns: 1fr; gap: 1rem;
  }
  @media (min-width: 480px) { .moments-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .moments-grid { grid-template-columns: repeat(3, 1fr); } }

  .moment-card {
    position: relative; overflow: hidden;
    background: white; border: 1px solid var(--c-border);
    border-radius: 1.25rem; text-decoration: none;
    transition: box-shadow 0.3s, transform 0.3s;
  }
  :root.dark .moment-card { background: var(--c-bg-alt); }
  .moment-card:hover { box-shadow: 0 8px 40px rgba(47,47,47,0.1); transform: translateY(-2px); }
  .moment-card__inner { position: relative; z-index: 1; padding: 1.75rem; }
  .moment-card__icon { font-size: 2.25rem; margin-bottom: 1rem; line-height: 1; }
  .moment-card__title {
    font-family: var(--font-serif); font-size: 1.1rem; font-weight: 500;
    color: var(--c-text); margin-bottom: 0.375rem; line-height: 1.3;
  }
  .moment-card__tagline {
    font-family: var(--font-serif); font-style: italic;
    font-size: 0.875rem; color: var(--c-text-muted); margin-bottom: 0.625rem;
  }
  .moment-card__hook {
    font-size: 0.85rem; color: var(--c-text-faint); line-height: 1.6; margin-bottom: 1rem;
  }
  .moment-card__tags {
    display: flex; flex-wrap: wrap; gap: 0.375rem; margin-bottom: 1rem;
  }
  .moment-card__cta {
    font-size: 0.8rem; color: var(--c-accent-deep);
    opacity: 0; transition: opacity 0.25s;
  }
  .moment-card:hover .moment-card__cta { opacity: 1; }
  .moment-card__wash {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(135deg, var(--c-accent-light) 0%, transparent 60%);
    opacity: 0; transition: opacity 0.5s;
  }
  .moment-card:hover .moment-card__wash { opacity: 1; }

  .moments-empty {
    text-align: center; padding: 5rem 0;
    display: flex; flex-direction: column; align-items: center; gap: 1.5rem;
    color: var(--c-text-muted);
  }
</style>
