---
import Base from '../../layouts/Base.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { getEmDashCollection } from 'emdash';
import { Image } from 'emdash/ui';

const { entries: articles, cacheHint } = await getEmDashCollection('journal', {
  status: 'published',
  orderBy: { published_at: 'desc' },
  limit: 12,
});
Astro.cache.set(cacheHint);

const featured     = articles.find((a) => a.data.is_featured);
const foundational = articles.filter((a) => a.data.is_foundational && a !== featured);
const rest         = articles.filter((a) => a !== featured && !a.data.is_foundational);

const pageUrl = Astro.url.href;
const siteUrl = Astro.url.origin;
---

<Base
  title="Journal — Thoughtful Writing on AI, Emotion, and Presence"
  description="Brand philosophy, cultural critique, and thought leadership on emotional AI, loneliness, and the future of human-AI relationships. Thoughtful writing for thoughtful people."
  ogImage={featured?.data.cover_image?.src}
  llmSummary="The Deerra AI Journal publishes long-form essays and analysis on emotional AI, the design of presence, and the intersection of technology and human connection. Content includes brand philosophy, cultural critique, research-backed analysis, and ethical inquiry."
  llmIntent="Technologists, designers, and thoughtful consumers interested in deep thinking about AI, emotional design, and the future of human-AI relationships."
  focusKeyword="emotional AI journal essays"
>
  <SchemaOrg
    slot="schema"
    type="WebPage"
    url={pageUrl}
    siteUrl={siteUrl}
    title="Journal"
    description="Thoughtful essays on emotional AI and the future of human-AI presence."
    breadcrumbs={[{ label: 'Journal', url: '/journal' }]}
  />

  {/* Header */}
  <section class="journal-header">
    <div class="container-site journal-header__content">
      <p class="text-eyebrow">Essays & Analysis</p>
      <h1>Journal</h1>
      <div class="divider"></div>
      <p class="journal-header__desc">
        Thoughtful writing at the intersection of AI, emotion, and presence. Brand philosophy, cultural critique, and what comes next.
      </p>
    </div>
  </section>

  {/* Featured article */}
  {featured && (
    <section class="section">
      <div class="container-site">
        <a href={`/journal/${featured.id}`} class="journal-featured reveal">
          {featured.data.cover_image?.src && (
            <div class="journal-featured__img-wrap">
              <Image image={featured.data.cover_image} class="journal-featured__img" />
            </div>
          )}
          <div class="journal-featured__body">
            <p class="text-eyebrow">Featured</p>
            {featured.data.editorial_angle && (
              <p class="journal-featured__angle">{featured.data.editorial_angle.replace(/-/g, ' ')}</p>
            )}
            <h2 class="journal-featured__title">{featured.data.title}</h2>
            {featured.data.thesis && (
              <p class="journal-featured__thesis">"{featured.data.thesis}"</p>
            )}
            {featured.data.excerpt && (
              <p class="journal-featured__excerpt">{featured.data.excerpt}</p>
            )}
            <div class="journal-featured__meta">
              {featured.data.read_time && <span class="tag">{featured.data.read_time} read</span>}
              {featured.data.content_depth && <span class="tag">{featured.data.content_depth.replace(/-/g, ' ')}</span>}
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  {/* Foundational pieces */}
  {foundational.length > 0 && (
    <section class="section" style="background: var(--c-bg-alt);">
      <div class="container-site">
        <p class="text-eyebrow mb-6 reveal">Foundation</p>
        <div class="journal-grid stagger-children">
          {foundational.map((a) => (
            <a href={`/journal/${a.id}`} class="journal-card journal-card--foundational">
              {a.data.cover_image?.src && (
                <div class="journal-card__img-wrap">
                  <Image image={a.data.cover_image} class="journal-card__img" />
                </div>
              )}
              <div class="journal-card__body">
                {a.data.editorial_angle && (
                  <p class="text-eyebrow">{a.data.editorial_angle.replace(/-/g, ' ')}</p>
                )}
                <h3 class="journal-card__title">{a.data.title}</h3>
                {a.data.excerpt && <p class="journal-card__excerpt">{a.data.excerpt}</p>}
                {a.data.read_time && <span class="tag mt-2 inline-block">{a.data.read_time}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Rest */}
  {rest.length > 0 && (
    <section class="section">
      <div class="container-site">
        <p class="text-eyebrow mb-6 reveal">All essays</p>
        <div class="journal-grid stagger-children">
          {rest.map((a) => (
            <a href={`/journal/${a.id}`} class="journal-card">
              {a.data.cover_image?.src && (
                <div class="journal-card__img-wrap">
                  <Image image={a.data.cover_image} class="journal-card__img" />
                </div>
              )}
              <div class="journal-card__body">
                {a.data.editorial_angle && (
                  <p class="text-eyebrow">{a.data.editorial_angle.replace(/-/g, ' ')}</p>
                )}
                <h3 class="journal-card__title">{a.data.title}</h3>
                {a.data.excerpt && <p class="journal-card__excerpt">{a.data.excerpt}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {articles.length === 0 && (
    <section class="section">
      <div class="container-narrow text-center">
        <p style="color: var(--c-text-muted);">Essays are being written. Return soon.</p>
        <a href="/_emdash/admin/content/journal/new" class="btn btn-ghost mt-6 inline-flex">
          Create first essay →
        </a>
      </div>
    </section>
  )}
</Base>

<style>
  .journal-header {
    padding: 5rem clamp(1.25rem, 5vw, 3rem) 4rem;
    background: var(--c-bg-alt);
  }
  .journal-header__desc {
    font-size: 1.1rem; line-height: 1.7;
    color: var(--c-text-muted); max-width: 38rem; margin-top: 0.75rem;
  }

  /* Featured */
  .journal-featured {
    display: flex; flex-direction: column;
    background: white; border: 1px solid var(--c-border);
    border-radius: 1.5rem; overflow: hidden;
    text-decoration: none;
    transition: box-shadow 0.3s, transform 0.3s;
  }
  :root.dark .journal-featured { background: var(--c-bg-alt); }
  .journal-featured:hover {
    box-shadow: 0 10px 48px rgba(47,47,47,0.1);
    transform: translateY(-3px);
  }
  @media (min-width: 768px) { .journal-featured { flex-direction: row; } }
  .journal-featured__img-wrap { overflow: hidden; aspect-ratio: 16/9; }
  @media (min-width: 768px) {
    .journal-featured__img-wrap { width: 45%; aspect-ratio: auto; flex-shrink: 0; }
  }
  .journal-featured__img { width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s ease; }
  .journal-featured:hover .journal-featured__img { transform: scale(1.04); }
  .journal-featured__body { padding: 2.5rem; display: flex; flex-direction: column; justify-content: center; }
  .journal-featured__angle {
    font-size: 0.8rem; color: var(--c-text-faint); margin: 0.5rem 0;
    text-transform: capitalize;
  }
  .journal-featured__title {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.5vw, 2rem);
    font-weight: 500; letter-spacing: -0.02em;
    color: var(--c-text); margin-bottom: 1rem; line-height: 1.2;
  }
  .journal-featured__thesis {
    font-family: var(--font-serif); font-style: italic;
    font-size: 1.05rem; line-height: 1.65;
    color: var(--c-text-muted); margin-bottom: 1rem;
    border-left: 2px solid var(--c-accent);
    padding-left: 1rem;
  }
  .journal-featured__excerpt {
    font-size: 0.9rem; line-height: 1.7; color: var(--c-text-faint);
    margin-bottom: 1.25rem;
  }
  .journal-featured__meta { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  /* Grid */
  .journal-grid {
    display: grid; grid-template-columns: 1fr; gap: 1.25rem;
  }
  @media (min-width: 640px) { .journal-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .journal-grid { grid-template-columns: repeat(3, 1fr); } }

  .journal-card {
    background: white; border: 1px solid var(--c-border);
    border-radius: 1.25rem; overflow: hidden;
    text-decoration: none; display: flex; flex-direction: column;
    transition: box-shadow 0.3s, transform 0.3s;
  }
  :root.dark .journal-card { background: var(--c-bg-deep); }
  .journal-card--foundational { border-color: var(--c-accent); }
  .journal-card:hover {
    box-shadow: 0 8px 32px rgba(47,47,47,0.08);
    transform: translateY(-2px);
  }
  .journal-card__img-wrap { aspect-ratio: 16/9; overflow: hidden; }
  .journal-card__img { width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.5s ease; }
  .journal-card:hover .journal-card__img { transform: scale(1.04); }
  .journal-card__body { padding: 1.5rem; flex: 1; }
  .journal-card__title {
    font-family: var(--font-serif); font-size: 1.1rem; font-weight: 500;
    letter-spacing: -0.01em; color: var(--c-text);
    margin: 0.4rem 0 0.625rem; line-height: 1.3;
  }
  .journal-card__excerpt {
    font-size: 0.875rem; line-height: 1.65; color: var(--c-text-muted); margin: 0;
  }
</style>
